{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "sveltekit",
      "routePrefix": "/"
    },
    "eve": {
      "buildCommand": "eve build",
      "entrypoint": ".",
      "framework": "eve",
      "routePrefix": "/_eve_internal/eve"
    }
  },
  "rewrites": [
    {
      "source": "/eve/v1/:path*",
      "destination": "/_eve_internal/eve/eve/v1/:path*"
    }
  ]
}
