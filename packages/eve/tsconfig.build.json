{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declarationMap": false,
    "sourceMap": false,
    "emitDeclarationOnly": true
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.integration.test.ts",
    "src/internal/testing/**/*.ts",
    "src/setup/build.ts"
  ]
}
