{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
